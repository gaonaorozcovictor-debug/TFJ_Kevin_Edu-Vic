Options -Indexes

# Redirigir todo al index.php excepto archivos/directorios reales
RewriteEngine On
RewriteBase /asignaciones/

# Permitir acceso a archivos y carpetas reales (CSS, imágenes, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás pasa por index.php
RewriteRule ^(.*)$ index.php [QSA,L]
